#!/usr/bin/env bash
# Thin wrapper — delegates to the Python CLI.
# Requires Python 3.11+.
set -euo pipefail

PY="$(command -v python3 2>/dev/null || true)"
if [[ -z "$PY" ]]; then
  echo "ERROR: python3 not found." >&2
  exit 1
fi

MAJOR_MINOR="$("$PY" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
MAJOR="${MAJOR_MINOR%%.*}"
MINOR="${MAJOR_MINOR#*.}"
if [[ "$MAJOR" -lt 3 || ("$MAJOR" -eq 3 && "$MINOR" -lt 11) ]]; then
  echo "ERROR: Python >= 3.11 required (found $MAJOR_MINOR)" >&2
  exit 1
fi

exec "$PY" "$(dirname "$0")/cli/quickstart.py" "$@"
