# ═══════════════════════════════════════════════════════════════════
# DatasheetMiner — app/.env.example
#
# Copy to app/.env.<stage> (dev|staging|prod). Quickstart auto-loads
# app/.env.${STAGE} on deploy. For raw `npx cdk <diff|import|deploy>`
# commands (migrations, debugging), source the file:
#     set -a; source app/.env.prod; set +a
# ═══════════════════════════════════════════════════════════════════

# ── Stage selection ──────────────────────────────────────────────────
# dev     → products-dev,     DatasheetMiner-Dev-*
# staging → products-staging, DatasheetMiner-Staging-*
# prod    → products-prod,    DatasheetMiner-Prod-*
STAGE=dev

# ── AWS ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id
# CDK internals read CDK_DEFAULT_* for lookups/bootstrap when invoked
# directly (not via Quickstart, which injects them). Mirror AWS_* above
# so `source app/.env.<stage> && npx cdk diff` works without exports.
CDK_DEFAULT_ACCOUNT=your-account-id
CDK_DEFAULT_REGION=us-east-1

# ── DynamoDB ─────────────────────────────────────────────────────────
# Defaults to products-${STAGE} when unset.
DYNAMODB_TABLE_NAME=products-dev

# ── App mode ─────────────────────────────────────────────────────────
# admin  → local full-access (all CRUD, management UI)
# public → cloud read-only (GET endpoints, product viewer, deployed)
APP_MODE=admin

# ── Backend (local dev only) ─────────────────────────────────────────
PORT=3001
NODE_ENV=development
REACT_APP_API_URL=http://localhost:3001

# ── Custom domain (prod only; leave unset for dev/staging) ───────────
DOMAIN_NAME=
CERTIFICATE_ARN=
HOSTED_ZONE_ID=
# Optional — defaults to the parent of DOMAIN_NAME (e.g. advin.io for
# datasheets.advin.io). Only set when the record lives in a delegated
# subdomain zone.
HOSTED_ZONE_NAME=

# ── SES sender for Cognito emails (Phase 5a) ─────────────────────────
# Both SES_FROM_EMAIL and SES_VERIFIED_DOMAIN must be set, or both
# unset. Half-set raises at config load.
#
# Unset (default): Cognito uses its built-in sender. 50 emails/day
#   sandbox cap. Fine for local synth + dev deploys; insufficient
#   for any stage with real signup volume.
# Set: Cognito sends through the given SES verified identity. The
#   from-domain must already be verified in SES (and ideally with
#   DKIM CNAMEs in Route53). Production also needs SES out of
#   sandbox — open a Production Access ticket in the AWS Console.
SES_FROM_EMAIL=
SES_FROM_NAME=
SES_REPLY_TO=
SES_VERIFIED_DOMAIN=
