# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# Stage controls resource naming: dev | staging | prod
# dev -> products-dev table, DatasheetMiner-Dev-* stacks
# prod -> products-prod table, DatasheetMiner-Prod-* stacks
STAGE=dev
DYNAMODB_TABLE_NAME=products-dev

# Backend Configuration
PORT=3001
NODE_ENV=development

# App mode: admin (local, full access) | public (cloud, read-only)
# admin = all CRUD endpoints, Management UI, Datasheets editing
# public = GET endpoints only, product viewer, no write operations
APP_MODE=admin

# Frontend Configuration (if needed)
REACT_APP_API_URL=http://localhost:3001

# Optional: Domain and HTTPS Configuration
DOMAIN_NAME=
CERTIFICATE_ARN=
HOSTED_ZONE_ID=
